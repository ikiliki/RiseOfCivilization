{
  "name": "@roc/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx watch src/index.ts",
    "start:local": "cross-env SERVER_PORT=4000 SERVER_DISPLAY_NAME=Scania DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/roc_scania tsx watch src/index.ts",
    "start:docker": "cross-env SERVER_PORT=4001 SERVER_DISPLAY_NAME=Bera DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/roc_bera tsx watch src/index.ts",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@roc/shared-types": "workspace:*",
    "@roc/world-engine": "workspace:*",
    "fastify": "^5.5.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "tsx": "^4.20.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.5",
    "cross-env": "^7.0.3"
  }
}

{
  "name": "@roc/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "vite",
    "start:local": "cross-env VITE_API_BASE_URL=http://localhost:4000 vite --port 5174",
    "start:docker": "cross-env VITE_API_BASE_URL=http://localhost:4001 vite --port 5175",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.3.0",
    "@roc/shared-types": "workspace:*",
    "@roc/ui": "workspace:*",
    "@roc/world-engine": "workspace:*",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.180.0",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.180.0",
    "cross-env": "^7.0.3",
    "storybook": "^8.6.18"
  }
}
